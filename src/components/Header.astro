---
import { Icon } from 'astro-icon/components';
import MobileMenu from './MobileMenu';
import { siteConfig } from '@config/site';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50"
  style="background: rgba(9, 9, 11, 0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid var(--color-border);"
>
  <div class="container">
    <nav
      class="flex items-center justify-between"
      style="height: 4rem;"
      aria-label="Main navigation"
    >
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2"
        style="text-decoration: none;"
        aria-label={siteConfig.name}
      >
        <div
          style="width: 2rem; height: 2rem; background: var(--color-accent); border-radius: 0.375rem; display: flex; align-items: center; justify-content: center;"
        >
          <span style="font-family: var(--font-display); font-weight: 700; font-size: 1rem; color: white; line-height: 1;">F</span>
        </div>
        <span style="font-family: var(--font-display); font-weight: 600; font-size: 1.0625rem; color: var(--color-text); letter-spacing: -0.01em;">
          Forge Studio
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">
        {siteConfig.nav.links.map(link => (
          <a
            href={link.href}
            class={`btn btn-ghost text-sm ${isActive(link.href) ? 'text-[var(--color-text)]' : ''}`}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop CTA + Mobile menu -->
      <div class="flex items-center gap-3">
        <a
          href={siteConfig.nav.cta.href}
          class="btn btn-primary hidden md:inline-flex"
          style="font-size: 0.875rem; padding: 0.5625rem 1.25rem;"
        >
          {siteConfig.nav.cta.label}
          <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
        </a>

        <!-- Mobile menu (React island — needs AnimatePresence for exit anim) -->
        <MobileMenu
          links={siteConfig.nav.links}
          cta={siteConfig.nav.cta}
          client:load
        />
      </div>
    </nav>
  </div>
</header>

<!-- Spacer so content starts below fixed header -->
<div style="height: 4rem;" aria-hidden="true"></div>

<script>
  import { animate } from "motion";

  let lastY = window.scrollY;
  let hidden = false;

  function initHeaderBehavior() {
    lastY = window.scrollY;
    hidden = false;

    window.addEventListener("scroll", () => {
      const currentY = window.scrollY;
      const scrolledDown = currentY > lastY;
      const pastThreshold = currentY > 80;

      if (scrolledDown && pastThreshold && !hidden) {
        animate("#site-header", { y: "-100%" }, { duration: 0.25, easing: "ease-in" });
        hidden = true;
      } else if (!scrolledDown && hidden) {
        animate("#site-header", { y: "0%" }, { duration: 0.3, easing: "ease-out" });
        hidden = false;
      }

      lastY = currentY;
    }, { passive: true });
  }

  initHeaderBehavior();
  document.addEventListener("astro:page-load", initHeaderBehavior);
</script>
