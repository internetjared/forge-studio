---
interface Props {
  variant?: 'default' | 'accent' | 'warm';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variantClass = {
  default: 'badge',
  accent: 'badge badge-accent',
  warm: 'badge badge-warm',
}[variant];
---

<span class={`${variantClass} ${className}`}>
  <slot />
</span>

<style>
  .badge-warm {
    border-color: var(--color-warm-subtle);
    color: var(--color-warm);
    background: var(--color-warm-subtle);
  }
</style>
