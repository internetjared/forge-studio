---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  badge,
  title,
  subtitle,
  align = 'left',
  class: className = '',
} = Astro.props;

const textAlign = align === 'center' ? 'text-align: center;' : '';
const maxWidth = align === 'center' ? 'max-width: 42rem; margin-left: auto; margin-right: auto;' : '';
---

<div
  class={`section-header reveal ${className}`}
  style={`${textAlign} ${maxWidth}`}
>
  {badge && (
    <span class="badge badge-accent" style="margin-bottom: 1.25rem; display: inline-flex;">
      {badge}
    </span>
  )}
  <h2 class="heading-xl" style="margin-bottom: 1rem; white-space: pre-line;">
    {title}
  </h2>
  {subtitle && (
    <p class="body-lg" style={`color: var(--color-text-muted); ${align === 'center' ? 'max-width: 38rem; margin-left: auto; margin-right: auto;' : 'max-width: 36rem;'}`}>
      {subtitle}
    </p>
  )}
</div>
