---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactForm from '@components/ContactForm.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@config/site';
---

<BaseLayout
  title="Contact"
  description="Start a project with Forge Studio. Free 30-minute discovery call, no commitment."
>
  <!-- Page header -->
  <section class="section">
    <div class="container">
      <div class="contact-layout">
        <!-- Left: Form -->
        <div class="contact-form-col">
          <span class="badge badge-accent animate-badge" style="margin-bottom: 1.5rem; display: inline-flex;">Start a project</span>
          <h1 class="heading-xl animate-title" style="margin-bottom: 1rem;">
            Let's build something<br>
            <em style="font-style: normal; color: var(--color-accent);">worth remembering.</em>
          </h1>
          <p class="body-lg animate-subtitle" style="color: var(--color-text-muted); margin-bottom: 3rem; max-width: 30rem;">
            Tell us what you're working on. We'll respond within one business day with honest thoughts on whether we're the right fit.
          </p>

          <div class="animate-cta">
            <ContactForm />
          </div>
        </div>

        <!-- Right: Info sidebar -->
        <aside class="contact-sidebar animate-visual">
          <!-- Office info card -->
          <div class="contact-info-card">
            <h2 style="font-family: var(--font-display); font-size: 1.125rem; font-weight: 600; margin: 0 0 1.5rem; color: var(--color-text);">Get in touch</h2>

            <div class="contact-info-items">
              <!-- Email -->
              <div class="contact-info-item">
                <div class="contact-icon-wrap">
                  <Icon name="lucide:mail" class="w-4 h-4" />
                </div>
                <div>
                  <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-subtle); margin-bottom: 0.25rem;">Email</div>
                  <a href={`mailto:${siteConfig.email}`} style="color: var(--color-text); text-decoration: none; font-size: 0.9375rem;" class="contact-link">{siteConfig.email}</a>
                </div>
              </div>

              <!-- Phone -->
              <div class="contact-info-item">
                <div class="contact-icon-wrap">
                  <Icon name="lucide:phone" class="w-4 h-4" />
                </div>
                <div>
                  <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-subtle); margin-bottom: 0.25rem;">Phone</div>
                  <a href={`tel:${siteConfig.phone.replace(/\D/g, '')}`} style="color: var(--color-text); text-decoration: none; font-size: 0.9375rem;" class="contact-link">{siteConfig.phone}</a>
                </div>
              </div>

              <!-- Address -->
              <div class="contact-info-item">
                <div class="contact-icon-wrap">
                  <Icon name="lucide:map-pin" class="w-4 h-4" />
                </div>
                <div>
                  <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-subtle); margin-bottom: 0.25rem;">Office</div>
                  <address style="color: var(--color-text); font-style: normal; font-size: 0.9375rem; line-height: 1.5;">
                    {siteConfig.address.street}<br>
                    {siteConfig.address.city}
                  </address>
                </div>
              </div>
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="map-placeholder" aria-hidden="true">
            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem;">
              <Icon name="lucide:map" class="w-6 h-6" style="color: var(--color-text-subtle);" />
              <span style="font-size: 0.8125rem; color: var(--color-text-subtle);">Columbus, Ohio</span>
            </div>
            <!-- Dot grid inside map -->
            <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255, 255, 255, 0.04) 1px, transparent 1px); background-size: 20px 20px;"></div>
          </div>

          <!-- Response time card -->
          <div class="response-card">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
              <div style="width: 0.625rem; height: 0.625rem; border-radius: 50%; background: #22c55e; animation: glowPulse 2s ease-in-out infinite;"></div>
              <span style="font-weight: 600; font-size: 0.9375rem; color: var(--color-text);">Usually respond within 24 hours</span>
            </div>
            <p style="font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.6; margin: 0;">
              We read every message. If we're not the right fit, we'll tell you honestly and recommend someone who is.
            </p>
          </div>

          <!-- Social links -->
          <div class="social-row">
            {siteConfig.footer.social.map(social => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.name}
                class="social-link-card"
              >
                <Icon name={social.icon} class="w-4 h-4" />
                <span style="font-size: 0.875rem; font-weight: 500;">{social.name}</span>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 1024px) {
    .contact-layout {
      grid-template-columns: 7fr 4fr;
      gap: 5rem;
    }
  }

  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .contact-info-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-info-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .contact-icon-wrap {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-md);
    background: var(--color-accent-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .contact-link:hover {
    color: var(--color-accent);
  }

  .map-placeholder {
    position: relative;
    border-radius: var(--radius-lg);
    aspect-ratio: 16/9;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .response-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .social-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .social-link-card {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-link-card:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
    background: var(--color-surface-raised);
  }
</style>

<script>
  import { animate, inView } from "motion";

  function initContact() {
    document.querySelectorAll(".reveal").forEach(el => {
      inView(el as Element, () => {
        animate(
          el,
          { opacity: [0, 1], y: [20, 0] },
          { duration: 0.5, easing: [0.16, 1, 0.3, 1] }
        );
      });
    });
  }

  initContact();
  document.addEventListener("astro:page-load", initContact);
</script>
